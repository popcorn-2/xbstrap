def get_host_triple():
    arch = platform.machine().lower()
    if arch in ('amd64', 'x86_64'):
        arch = 'x86_64'
    elif arch in ('aarch64', 'arm64'):
        arch = 'aarch64'
        
    sys_name = platform.system().lower()
    if sys_name == 'darwin':
        return f"{arch}-apple-darwin"
    elif sys_name == 'windows':
        return f"{arch}-pc-windows-msvc"
    else:
        return f"{arch}-unknown-linux-gnu"

class Package:
    def __init__(self, data, manifest_dir):
        self.name = data.get('name')
        self.system = data.get('system', False)
        self.git = data.get('git')
        self.source = data.get('source')
        self.binary_url = data.get('binary-url')
        self.license = data.get('license')
        self.author = data.get('author', [])
        self.maintainer = data.get('maintainer', [])
        
        self.available_features = self._parse_features(data.get('features', []))
        
        # Package-specific custom commands
        self.commands = {}
        for k, v in data.get('commands', {}).items():
            self.commands[k] = " ".join(v) if isinstance(v, list) else str(v)
        
        # Keep dependencies as raw lists to evaluate {FEAT...} macros dynamically
        self.build_depends = data.get('build-depends', [])
        self.depends = data.get('depends', [])
        
        self.configure = data.get('configure', [])
        self.build = data.get('build', [])
        self.install = data.get('install', [])
        self.post_install = data.get('post-install', [])
        
        self.triggers = {}
        for trig in data.get('triggers', []):
            if isinstance(trig, dict):
                for k, v in trig.items():
                    self.triggers[k] = v
                    
        self.manifest_dir = manifest_dir
        self.safe_name = self.name.replace('@', '').replace('/', '_')
        
        self.source_dir = Path.cwd() / "sources" / self.safe_name
        self.build_dir = Path.cwd() / "build-workspaces" / self.safe_name

    def _parse_features(self, feature_list):
        features = set()
        for item in feature_list:
            if isinstance(item, str):
                features.add(item)
            elif isinstance(item, dict):
                for key, subfeatures in item.items():
                    features.add(key)
                    if subfeatures:
                        for sub in subfeatures:
                            features.add(f"{key}-{sub}")
        return features

class Registry:
    def __init__(self):
        self.packages = {}
        self.loaded_files = set()
        self.commands = {}

    def load_manifest(self, filepath):
        filepath = Path(filepath).resolve()
        if filepath in self.loaded_files:
            return
        self.loaded_files.add(filepath)

        if not filepath.exists():
            print(f"Error: Manifest {filepath} not found.")
            sys.exit(1)

        with open(filepath, 'r') as f:
            data = yaml.safe_load(f) or {}

        for imp in data.get('imports', []):
            imp_path = (filepath.parent / imp).resolve()
            self.load_manifest(imp_path)

        # Load globally shared commands
        for k, v in data.get('commands', {}).items():
            self.commands[k] = " ".join(v) if isinstance(v, list) else str(v)

        for pkg_data in data.get('packages', []):
            pkg = Package(pkg_data, filepath.parent)
            self.packages[pkg.name] = pkg

    def get(self, name):
        if name not in self.packages:
            print(f"Error: Package '{name}' not found in registry.")
            sys.exit(1)
        return self.packages[name]

class Triple:
    def __init__(self, name):
        split = name.split("-")
        self.arch = split[0]
        self.vendor = split[1]
        self.os = split[2]
        self.abi = split[3] if 3 < len(split) else None
    
    def __repr__(self):
        return self.triple
    
    def __ne__(self, value):
        self.arch != value.arch or self.vendor != value.vendor or self.os != value.os or self.abi != value.abi

    @property
    def arch_alt(self):
        if self.arch == "x86_64":
            return "amd64"
        else:
            return self.arch

    @property
    def triple(self):
        if self.abi is not None:
            return f"{self.arch}-{self.vendor}-{self.os}-{self.abi}"
        else:
            return f"{self.arch}-{self.vendor}-{self.os}"

class InstalledManifest:
    def __init__(self, filepath):
        self.filepath = Path(filepath).resolve()
        self.installed = {}
        self.load()

    def load(self):
        if self.filepath.exists():
            try:
                with open(self.filepath, 'r') as f:
                    self.installed = json.load(f)
            except json.JSONDecodeError:
                self.installed = {}

    def save(self):
        self.filepath.parent.mkdir(parents=True, exist_ok=True)
        with open(self.filepath, 'w') as f:
            json.dump(self.installed, f, indent=2)

    def is_installed(self, name, features):
        if name not in self.installed:
            return False
        installed_feats = set(self.installed[name].get('features', []))
        return features.issubset(installed_feats)

    def mark_installed(self, name, features):
        existing_feats = set(self.installed.get(name, {}).get('features', []))
        new_feats = existing_feats | features
        self.installed[name] = {'features': sorted(list(new_feats))}
        self.save()

class Builder:
    def __init__(self, registry, base_sysroot, cache_dir, host_triple, target_triple, dry_run=False, from_source=None, local_sources=None):
        self.registry = registry
        self.base_sysroot = Path(base_sysroot).resolve()
        self.host_sysroot = Path.cwd() / "tools" if host_triple != target_triple else self.base_sysroot
        self.cache_dir = Path(cache_dir).resolve()
        self.host_triple = Triple(host_triple)
        self.target_triple = Triple(target_triple)
        self.dry_run = dry_run
        self.from_source = from_source
        
        # Initialize manifests
        self.target_manifest = InstalledManifest(self.base_sysroot / "system" / "etc" / "popcorn_manifest.json")
        if host_triple != target_triple:
            self.host_manifest = InstalledManifest(self.host_sysroot / "popcorn_manifest.json")
        else:
            # Prevent in-memory state overwrites if building tools in the same sysroot
            self.host_manifest = self.target_manifest
        
        self.local_sources = {}
        if local_sources:
            for ls in local_sources:
                if '=' not in ls:
                    print(f"Error: Invalid --local-source format '{ls}'. Expected pkg=path")
                    sys.exit(1)
                k, v = ls.split('=', 1)
                self.local_sources[k] = Path(v).resolve()
                
        # Override registry source directories for local sources right away
        for pkg_name, path in self.local_sources.items():
            if pkg_name in self.registry.packages:
                self.registry.packages[pkg_name].source_dir = path
        
        self.planned_features = {}
        self.has_binary_cache = {}
        self.queued_triggers = set()
        self.initial_targets = []
        self.github_assets_cache = {}

    def get_manifest(self, is_build_dep):
        return self.host_manifest if is_build_dep else self.target_manifest

    def plan_target(self, pkg_req, is_build_dep=False, no_install=False):
        self.initial_targets.append((pkg_req, is_build_dep, no_install))

    def parse_pkg_req(self, req_str):
        parts = req_str.split(':', 1)
        name = parts[0]
        features = set(parts[1].split(',')) if len(parts) > 1 and len(parts[1]) > 0 else set()
        return name, features

    def resolve_dep_str(self, dep_req, requested_features):
        def repl_feat(match):
            feat, val = match.groups()
            return val if feat in requested_features else ""
        def repl_nofeat(match):
            feat, val = match.groups()
            return val if feat not in requested_features else ""
            
        d = re.sub(r'\{FEAT:([a-zA-Z0-9_-]+):([^}]*)\}', repl_feat, dep_req)
        d = re.sub(r'\{NOFEAT:([a-zA-Z0-9_-]+):([^}]*)\}', repl_nofeat, d)
        return d.strip()

    def get_resolved_dep_names(self, raw_deps, features):
        names = set()
        for dep in raw_deps:
            d = self.resolve_dep_str(dep, features)
            if d:
                names.add(self.parse_pkg_req(d)[0])
        return names

    def get_staging_dir(self, pkg, is_build_dep):
        ty = "tools" if is_build_dep else "target"
        return Path.cwd() / "staging" / ty / pkg.safe_name

    def get_final_sysroot(self, pkg, is_build_dep):
        if is_build_dep:
            return self.host_sysroot
        elif pkg.system:
            return self.base_sysroot / "system"
        else:
            return self.base_sysroot / "pkg" / pkg.name.lstrip('@')

    def get_target_triple(self, is_build_dep):
        return self.host_triple if is_build_dep else self.target_triple

    def _get_feat_suffix(self, requested_features):
        return ("-" + "+".join(sorted(requested_features))) if requested_features else ""

    def get_archive_path(self, pkg, is_build_dep, requested_features):
        triple = self.get_target_triple(is_build_dep)
        feat_suffix = self._get_feat_suffix(requested_features)
        return self.cache_dir / f"{pkg.safe_name}{feat_suffix}-{triple.triple}.tar.gz"

    def get_feature_subset_match(self, available_files, template_name, pkg, is_build_dep, requested_features):
        target_triple = self.get_target_triple(is_build_dep).triple
        
        if '{FEATURES}' in template_name:
            prefix, suffix = template_name.split('{FEATURES}', 1)
        else:
            prefix = template_name
            suffix = ""

        prefix = prefix.replace('{SAFE_NAME}', pkg.safe_name).replace('{TARGET}', target_triple).replace('{NAME}', pkg.name)
        suffix = suffix.replace('{SAFE_NAME}', pkg.safe_name).replace('{TARGET}', target_triple).replace('{NAME}', pkg.name)

        candidates = []
        for f in available_files:
            if f.startswith(prefix) and f.endswith(suffix):
                feat_str = f[len(prefix):len(f)-len(suffix)]
                if feat_str == "":
                    feats = set()
                elif feat_str.startswith("-"):
                    feats = set(feat_str[1:].split("+"))
                else:
                    continue
                
                if requested_features.issubset(feats):
                    candidates.append((len(feats), feats, f))
        
        if candidates:
            candidates.sort(key=lambda x: (x[0], x[2]))
            return candidates[0]
        return None

    def find_local_cache(self, pkg, is_build_dep, requested_features):
        if not self.cache_dir.exists():
            return None
        available = os.listdir(self.cache_dir)
        template = "{SAFE_NAME}{FEATURES}-{TARGET}.tar.gz"
        match = self.get_feature_subset_match(available, template, pkg, is_build_dep, requested_features)
        if match:
            _, _, filename = match
            return self.cache_dir / filename
        return None

    def find_remote_binary(self, pkg, is_build_dep, requested_features):
        if not pkg.binary_url:
            return None, None
            
        gh_match = re.match(r'^https://github.com/([^/]+)/([^/]+)/releases/download/([^/]+)/(.*)$', pkg.binary_url)
        if not gh_match:
            target_triple = self.get_target_triple(is_build_dep).triple
            url = pkg.binary_url.replace('{NAME}', pkg.name).replace('{SAFE_NAME}', pkg.safe_name).replace('{TARGET}', target_triple).replace('{FEATURES}', self._get_feat_suffix(requested_features))
            try:
                urllib.request.urlopen(urllib.request.Request(url, method='HEAD', headers={'User-Agent': 'Mozilla/5.0'}))
                return url, requested_features
            except Exception:
                return None, None

        owner, repo, tag, filename_template = gh_match.groups()
        api_url = f"https://api.github.com/repos/{owner}/{repo}/releases/latest" if tag.lower() == 'latest' else f"https://api.github.com/repos/{owner}/{repo}/releases/tags/{tag}"
        
        if api_url not in self.github_assets_cache:
            try:
                req = urllib.request.Request(api_url, headers={'Accept': 'application/vnd.github.v3+json', 'User-Agent': 'Mozilla/5.0'})
                with urllib.request.urlopen(req) as response:
                    data = json.loads(response.read().decode('utf-8'))
                    self.github_assets_cache[api_url] = { asset['name']: asset['browser_download_url'] for asset in data.get('assets', []) }
            except Exception:
                self.github_assets_cache[api_url] = {}
                
        available_assets = list(self.github_assets_cache[api_url].keys())
        match = self.get_feature_subset_match(available_assets, filename_template, pkg, is_build_dep, requested_features)
        if match:
            _, matched_feats, matched_filename = match
            return self.github_assets_cache[api_url][matched_filename], matched_feats
            
        return None, None

    def check_has_binary(self, pkg, is_build_dep, requested_features):
        if pkg.name in self.local_sources:
            return False
            
        if self.from_source is not None:
            if len(self.from_source) == 0 or pkg.name in self.from_source:
                return False
            
        feat_tuple = tuple(sorted(requested_features))
        cache_key = (pkg.name, is_build_dep, feat_tuple)
        if cache_key in self.has_binary_cache:
            return self.has_binary_cache[cache_key]
            
        has_bin = False
        if self.find_local_cache(pkg, is_build_dep, requested_features):
            has_bin = True
        elif self.find_remote_binary(pkg, is_build_dep, requested_features)[0]:
            has_bin = True
            
        self.has_binary_cache[cache_key] = has_bin
        return has_bin

    def compute_plan(self):
        changed = True
        while changed:
            changed = False
            q = list(self.initial_targets)
            visited = set()
            
            while q:
                req, is_b, skip_install = q.pop(0)
                name, new_feats = self.parse_pkg_req(req)
                key = (name, is_b, skip_install)
                pkg = self.registry.get(name)
                
                invalid_feats = new_feats - pkg.available_features
                if invalid_feats:
                    print(f"\n[!] ERROR: Package '{name}' does not provide requested features: {', '.join(invalid_feats)}")
                    sys.exit(1)
                    
                if key not in self.planned_features:
                    self.planned_features[key] = set()
                    
                added = not new_feats.issubset(self.planned_features[key])
                if added:
                    self.planned_features[key] |= new_feats
                    changed = True
                    
                if key not in visited or added:
                    visited.add(key)
                    current_feats = self.planned_features[key]
                    
                    if not self.check_has_binary(pkg, is_b, current_feats):
                        for d in pkg.build_depends:
                            res = self.resolve_dep_str(d, current_feats)
                            if res: q.append((res, True, False))
                            
                    for d in pkg.depends:
                        res = self.resolve_dep_str(d, current_feats)
                        if res: q.append((res, is_b, False))
                        
        visited = set()
        order = []
        def dfs(n, is_b, skip_install):
            k = (n, is_b, skip_install)
            if k in visited: return
            visited.add(k)
            
            pkg = self.registry.get(n)
            current_feats = self.planned_features.get(k, set())
            
            if not self.check_has_binary(pkg, is_b, current_feats):
                for d in pkg.build_depends:
                    res = self.resolve_dep_str(d, current_feats)
                    if res: dfs(self.parse_pkg_req(res)[0], True, False)
                    
            for d in pkg.depends:
                res = self.resolve_dep_str(d, current_feats)
                if res: dfs(self.parse_pkg_req(res)[0], is_b, False)
                
            order.append(k)
            
        for req, is_b, skip_install in self.initial_targets:
            dfs(self.parse_pkg_req(req)[0], is_b, skip_install)
            
        return order

    def expand_command(self, cmd, pkg, is_build_dep, requested_features):
        if isinstance(cmd, list):
            cmd = " ".join(cmd)
            
        # Execute Alias / Custom Commands Expansion first
        parts = cmd.split(maxsplit=1)
        if parts:
            first_word = parts[0]
            cmd_template = pkg.commands.get(first_word) or self.registry.commands.get(first_word)
            if cmd_template:
                cmd_args = (parts[1].strip() if len(parts) > 1 else "").split(" ")

                def repl_cmdargs(match):
                    start = match.group(2)
                    end = match.group(4)
                    has_end = match.group(3) is not None

                    if start is None:
                        return " ".join(cmd_args)
                    elif has_end and end is not None:
                        return " ".join(cmd_args[int(start):int(end)])
                    elif has_end:
                        return " ".join(cmd_args[int(start):])
                    else:
                        return cmd_args[int(start)]

                cmd = re.sub(r"{CMD_ARGS(:(\d+)(..)?(\d+)?)?}", repl_cmdargs, cmd_template)

                if cmd == cmd_template: # we didn't match anything so just append them all
                    cmd = f"{cmd_template} {cmd_args}".strip()

        current_base = self.host_sysroot if is_build_dep else self.base_sysroot
        pkg_staging = self.get_staging_dir(pkg, is_build_dep)
        target_triple = self.get_target_triple(is_build_dep)

        cmd = cmd.replace('{BASE_SYSROOT}', str(current_base))
        cmd = cmd.replace('{SYSROOT}', str(pkg_staging))
        cmd = cmd.replace('{TARGET}', target_triple.triple)
        cmd = cmd.replace('{TARGET:arch}', target_triple.arch)
        cmd = cmd.replace('{TARGET:vendor}', target_triple.vendor)
        cmd = cmd.replace('{TARGET:os}', target_triple.os)
        cmd = cmd.replace('{TARGET:arch_alt}', target_triple.arch_alt)
        cmd = cmd.replace('{SOURCES}', str(pkg.source_dir))
        cmd = cmd.replace('{HOST}', self.host_triple.triple)
        cmd = cmd.replace('{HOST:arch}', self.host_triple.arch)
        cmd = cmd.replace('{HOST:vendor}', self.host_triple.vendor)
        cmd = cmd.replace('{HOST:os}', self.host_triple.os)
        cmd = cmd.replace('{HOST:arch_alt}', self.host_triple.arch_alt)
        
        active_build_deps = self.get_resolved_dep_names(pkg.build_depends, requested_features)
        active_run_deps = self.get_resolved_dep_names(pkg.depends, requested_features)
        
        def validate_dep(dep_name):
            if dep_name not in active_build_deps and dep_name not in active_run_deps:
                print(f"\n[!] ERROR: Package '{pkg.name}' referenced '{dep_name}' via BINDEP/BUILDDEP/SRCDEP but it is not an active dependency.")
                sys.exit(1)

        def repl_bindep(match):
            dep_name = match.group(1)
            validate_dep(dep_name)
            dep_pkg = self.registry.get(dep_name)
            dep_is_build = True if dep_name in active_build_deps else is_build_dep
            return str(self.get_final_sysroot(dep_pkg, dep_is_build))

        def repl_builddep(match):
            dep_name = match.group(1)
            validate_dep(dep_name)
            return str(self.registry.get(dep_name).build_dir)

        def repl_srcdep(match):
            dep_name = match.group(1)
            validate_dep(dep_name)
            return str(self.registry.get(dep_name).source_dir)

        cmd = re.sub(r'\{BINDEP:([^}]+)\}', repl_bindep, cmd)
        cmd = re.sub(r'\{BUILDDEP:([^}]+)\}', repl_builddep, cmd)
        cmd = re.sub(r'\{SRCDEP:([^}]+)\}', repl_srcdep, cmd)
        
        def repl_feat(match):
            feat, val = match.groups()
            return val if feat in requested_features else ""
            
        def repl_nofeat(match):
            feat, val = match.groups()
            return val if feat not in requested_features else ""
            
        cmd = re.sub(r'\{FEAT:([a-zA-Z0-9_-]+):([^}]*)\}', repl_feat, cmd)
        cmd = re.sub(r'\{NOFEAT:([a-zA-Z0-9_-]+):([^}]*)\}', repl_nofeat, cmd)
        
        return cmd.strip()

    def run_command(self, cmd, cwd):
        prefix = "[DRY-RUN] " if self.dry_run else "[EXEC] "
        print(f"    {prefix}{cmd}")
        if not self.dry_run:
            cwd.mkdir(parents=True, exist_ok=True)
            subprocess.run(cmd, cwd=cwd, shell=True, check=True, executable='/bin/bash')

    def fetch(self, pkg):
        if pkg.name in self.local_sources:
            print(f"  -> Using local source override for {pkg.name}: {pkg.source_dir}")
            return
            
        if not self.dry_run:
            pkg.source_dir.parent.mkdir(parents=True, exist_ok=True)
            
        if pkg.git:
            if not pkg.source_dir.exists() and not self.dry_run:
                if isinstance(pkg.git, str):
                    git = pkg.git
                    recursive = False
                else:
                    git = pkg.git["source"]
                    recursive = pkg.git.get("recursive", False)
                submodules = " and submodules" if recursive else ""
                print(f"  -> Cloning `{git}`{submodules}")
                cmd = ["git", "clone"]
                if recursive:
                    cmd.append("--recurse-submodules")
                cmd += [git, str(pkg.source_dir)]
                subprocess.run(cmd, check=True)
            else:
                print(f"  -> Source ready: {pkg.git}")
        elif pkg.source:
            source_pkg = self.registry.get(pkg.source)
            print(f"  -> Using source from {source_pkg.name}")
            # Ensure the source we are relying on is also fetched!
            if not source_pkg.source_dir.exists() and not self.dry_run:
                self.fetch(source_pkg)
            
            if not pkg.source_dir.exists() and not self.dry_run:
                os.symlink(source_pkg.source_dir, pkg.source_dir)

    def download_binary_from_url(self, url, target_cache_path):
        print(f"  -> Downloading binary from {url}")
        if self.dry_run:
            return True

        target_cache_path.parent.mkdir(parents=True, exist_ok=True)
        try:
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0 Popcorn/2.0'})
            with urllib.request.urlopen(req) as response, open(target_cache_path, 'wb') as out_file:
                total_size = int(response.info().get('Content-Length', -1))
                downloaded = 0
                chunk_size = 8192
                while True:
                    chunk = response.read(chunk_size)
                    if not chunk: break
                    out_file.write(chunk)
                    downloaded += len(chunk)
                    if total_size > 0:
                        percent = int((downloaded / total_size) * 100)
                        sys.stdout.write(f"\r  -> Progress: {percent}% ({downloaded}/{total_size} bytes)")
                        sys.stdout.flush()
                print()
            return True
        except urllib.error.URLError as e:
            print(f"\n  [!] Failed to download: {e}")
            if target_cache_path.exists(): target_cache_path.unlink()
            return False

    def create_archive(self, pkg, is_build_dep, requested_features):
        if self.dry_run: return
        archive_path = self.get_archive_path(pkg, is_build_dep, requested_features)
        archive_path.parent.mkdir(parents=True, exist_ok=True)
        staging_dir = self.get_staging_dir(pkg, is_build_dep)
        print(f"  -> Packaging {pkg.name} into {archive_path.name}...")
        with tarfile.open(archive_path, "w:gz") as tar:
            tar.add(staging_dir, arcname=".")

    def extract_archive(self, archive_path, pkg, is_build_dep):
        if not archive_path.exists(): return False
        if not self.dry_run:
            final_dir = self.get_final_sysroot(pkg, is_build_dep)
            final_dir.mkdir(parents=True, exist_ok=True)
            print(f"  -> Extracting {archive_path.name} to {final_dir}...")
            with tarfile.open(archive_path, "r:gz") as tar:
                tar.extractall(path=final_dir)
        return True

    def _queue_triggers(self, pkg, is_build_dep):
        for trigger_req in pkg.post_install:
            t_pkg_name, t_name = trigger_req.rsplit(':', 1)
            t_pkg = self.registry.get(t_pkg_name)
            if t_name not in t_pkg.triggers:
                print(f"\n[!] ERROR: Package '{pkg.name}' requested trigger '{t_name}' from '{t_pkg_name}', but it doesn't exist.")
                sys.exit(1)
            self.queued_triggers.add((t_pkg_name, t_name, is_build_dep))

    def _finalize_install(self, pkg, is_build_dep, requested_features, skip_triggers):
        if not skip_triggers:
            self._queue_triggers(pkg, is_build_dep)
        if not self.dry_run:
            self.get_manifest(is_build_dep).mark_installed(pkg.name, requested_features)

    def execute_single(self, pkg, is_build_dep, requested_features, create_tarball=False, skip_triggers=False, skip_install=False):
        manifest = self.get_manifest(is_build_dep)
        
        # Determine if we should skip the install
        is_local_override = pkg.name in self.local_sources
        explicit_from_source = self.from_source is not None and (len(self.from_source) == 0 or pkg.name in self.from_source)
        
        if not is_local_override and not explicit_from_source and not skip_install and manifest.is_installed(pkg.name, requested_features):
            print(f"  -> {pkg.name} is already installed with features [{', '.join(requested_features)}]. Skipping.")
            return

        print(f"\n>>> Processing {pkg.name} [{'BUILD DEP' if is_build_dep else 'TARGET'}] (Features: {requested_features})")

        if not self.check_has_binary(pkg, is_build_dep, requested_features) and not create_tarball and (self.from_source is None or pkg.name not in self.from_source and len(self.from_source) > 0 and pkg.name not in self.local_sources):
            cached_path = self.find_local_cache(pkg, is_build_dep, requested_features)
            if cached_path:
                print(f"  -> Found suitable cached binary: {cached_path.name}")
                if self.extract_archive(cached_path, pkg, is_build_dep):
                    self._finalize_install(pkg, is_build_dep, requested_features, skip_triggers)
                    return
            
            remote_url, matched_feats = self.find_remote_binary(pkg, is_build_dep, requested_features)
            if remote_url:
                target_cache_path = self.get_archive_path(pkg, is_build_dep, matched_feats)
                if self.download_binary_from_url(remote_url, target_cache_path):
                    if self.extract_archive(target_cache_path, pkg, is_build_dep):
                        print(f"  -> Successfully installed {pkg.name} from downloaded binary.")
                        self._finalize_install(pkg, is_build_dep, requested_features, skip_triggers)
                        return
            
            print(f"  -> No binary cache available for {pkg.name} with features {requested_features}. Falling back to source build.")
        elif self.check_has_binary(pkg, is_build_dep, requested_features):
             cached_path = self.find_local_cache(pkg, is_build_dep, requested_features)
             if cached_path and self.extract_archive(cached_path, pkg, is_build_dep):
                 self._finalize_install(pkg, is_build_dep, requested_features, skip_triggers)
                 return
                 
             remote_url, matched_feats = self.find_remote_binary(pkg, is_build_dep, requested_features)
             if remote_url:
                 target_cache_path = self.get_archive_path(pkg, is_build_dep, matched_feats)
                 if self.download_binary_from_url(remote_url, target_cache_path) and self.extract_archive(target_cache_path, pkg, is_build_dep):
                     print(f"  -> Successfully installed {pkg.name} from downloaded binary.")
                     self._finalize_install(pkg, is_build_dep, requested_features, skip_triggers)
                     return

        if not self.dry_run:
            staging_dir = self.get_staging_dir(pkg, is_build_dep)
            if staging_dir.exists(): shutil.rmtree(staging_dir)
            staging_dir.mkdir(parents=True, exist_ok=True)

        self.fetch(pkg)

        if pkg.configure:
            cmd = self.expand_command(pkg.configure, pkg, is_build_dep, requested_features)
            self.run_command(cmd, pkg.build_dir) 

        if pkg.build:
            for step in (pkg.build if isinstance(pkg.build, list) else [pkg.build]):
                cmd = self.expand_command(step, pkg, is_build_dep, requested_features)
                self.run_command(cmd, pkg.build_dir)
        
        # If we only want to build, do not merge into sysroot or mark as installed
        if skip_install:
            return

        if pkg.install:
            for step in (pkg.install if isinstance(pkg.install, list) else [pkg.install]):
                cmd = self.expand_command(step, pkg, is_build_dep, requested_features)
                self.run_command(cmd, pkg.build_dir)

        if create_tarball:
            self.create_archive(pkg, is_build_dep, requested_features)

        if not self.dry_run:
            staging_dir = self.get_staging_dir(pkg, is_build_dep)
            final_dir = self.get_final_sysroot(pkg, is_build_dep)
            print(f"  -> Merging staging directory into {final_dir}")
            shutil.copytree(staging_dir, final_dir, dirs_exist_ok=True)

        self._finalize_install(pkg, is_build_dep, requested_features, skip_triggers)

    def execute(self, create_tarball=False, skip_triggers=False):
        order = self.compute_plan()
        target_keys = set(self.parse_pkg_req(req)[0] for req, _, _ in self.initial_targets)
        
        for key in order:
            name, is_build_dep, skip_install = key
            pkg = self.registry.get(name)
            features = self.planned_features[key]
            
            is_target = name in target_keys
            do_tarball = create_tarball and is_target
            
            self.execute_single(pkg, is_build_dep, features, do_tarball, skip_triggers, skip_install)
            
        if not skip_triggers:
            print("\n>>> Executing Post-Install Triggers")
            for t_pkg_name, t_name, is_build_dep in self.queued_triggers:
                print(f"  -> Trigger: {t_pkg_name}:{t_name}")
                t_pkg = self.registry.get(t_pkg_name)
                cmd_template = t_pkg.triggers[t_name]
                cmd = self.expand_command(cmd_template, t_pkg, is_build_dep, set())
                trigger_cwd = self.host_sysroot if is_build_dep else self.base_sysroot
                self.run_command(cmd, trigger_cwd)

def main():
    parser = argparse.ArgumentParser(description="Popcorn2 Package Manager & Bootstrap System")
    
    parser.add_argument('--manifest', default=f"{os.path.dirname(__file__)}/packages.yml", help="Root YAML manifest file")
    parser.add_argument('--sysroot', default='/', help="Base target sysroot directory")
    parser.add_argument('--cache-dir', default='./cache', help="Directory to store/fetch pre-built package tarballs")
    parser.add_argument('--target', help="Cross-compile target triple")
    parser.add_argument('--host', help="Host architecture triple")
    parser.add_argument('--from-source', nargs='*', default=None, metavar='PKG', help="Force build from source (ignore binary caches). Pass package names to force specific ones, or omit arguments to force all.")
    parser.add_argument('--local-source', action='append', default=[], metavar='PKG=PATH', help="Override source directory for a package (format: pkg=path), e.g. @core/example=./my-src")
    parser.add_argument('--dry-run', action='store_true', help="Print commands without executing them")
    parser.add_argument('--as-build-dep', help="Build as if it was a build dependecy rather than for the target", action='store_true')
    
    subparsers = parser.add_subparsers(dest='command', required=True)

    install_parser = subparsers.add_parser('install', help="Install a package")
    install_parser.add_argument('package', help="Package target, e.g. @core/example:cxx", nargs="+")

    build_parser = subparsers.add_parser('build', help="Build a package")
    build_parser.add_argument('package', help="Package target, e.g. @core/example:cxx", nargs="+")

    pkg_parser = subparsers.add_parser('package', help="Build package from source and generate a binary tarball archive")
    pkg_parser.add_argument('package', help="Package target, e.g. @core/example:cxx", nargs="+")
    
    run_parser = subparsers.add_parser('run', help="Run a custom command inside the package's build directory")
    run_parser.add_argument('package', help="Package target, e.g. @core/example")
    run_parser.add_argument('cmd', help="Command alias or binary to run")
    run_parser.add_argument('cmd_args', nargs=argparse.REMAINDER, help="Additional arguments to pass to the command")
    
    info_parser = subparsers.add_parser('info', help="Print parsed package information")
    info_parser.add_argument('package', help="Package name to inspect")
    info_parser.add_argument('--sources', action='store_true')
    info_parser.add_argument('--build-dir', action='store_true')

    args = parser.parse_args()
    host_triple = args.host or get_host_triple()
    target_triple = args.target or host_triple

    registry = Registry()
    registry.load_manifest(args.manifest)

    if args.command == 'info':
        pkg = registry.get(args.package.split(":")[0])

        specific_info_printed = False

        if args.sources:
            if specific_info_printed:
                print(" ", end="")
            print(pkg.source_dir, end="")
            specific_info_printed = True
        
        if args.build_dir:
            if specific_info_printed:
                print(" ", end="")
            print(pkg.build_dir, end="")
            specific_info_printed = True
        
        if specific_info_printed:
            print()
        else:
            print(f"Package: {pkg.name}")
            print(f"System Package: {'Yes (/system)' if pkg.system else 'No (/pkg)'}")
            print(f"Host Triple: {host_triple}")
            print(f"Target Triple: {target_triple}")
            print("-" * 40)
            print(yaml.dump({
                "features": list(pkg.available_features),
                "depends": pkg.depends,
                "build-depends": pkg.build_depends,
                "custom-commands": pkg.commands,
                "triggers_provided": list(pkg.triggers.keys()),
                "triggers_requested": pkg.post_install,
                "binary_url": pkg.binary_url
            }, sort_keys=False))
        sys.exit(0)

    builder = Builder(
        registry, 
        args.sysroot, 
        args.cache_dir, 
        host_triple, 
        target_triple, 
        args.dry_run, 
        args.from_source, 
        args.local_source
    )

    if args.command == 'install' or args.command == 'build':
        for pkg in args.package:
            builder.plan_target(pkg, args.as_build_dep, no_install=args.command == 'build')
        builder.execute()

    elif args.command == 'package':
        for pkg in args.package:
            builder.plan_target(pkg, args.as_build_dep)
        builder.execute(create_tarball=True, skip_triggers=True)

    elif args.command == 'run':
        pkg_name, features = builder.parse_pkg_req(args.package)
        pkg = registry.get(pkg_name)
        
        invalid_feats = features - pkg.available_features
        if invalid_feats:
            print(f"\n[!] ERROR: Package '{pkg_name}' does not provide requested features: {', '.join(invalid_feats)}")
            sys.exit(1)

        # 1. Resolve and install build and runtime dependencies
        for dep in pkg.build_depends:
            res = builder.resolve_dep_str(dep, features)
            if res: builder.plan_target(res, is_build_dep=True)
            
        for dep in pkg.depends:
            res = builder.resolve_dep_str(dep, features)
            if res: builder.plan_target(res, is_build_dep=args.as_build_dep)
            
        if builder.initial_targets:
            print(f"\n>>> Resolving and installing dependencies for {pkg.name}...")
            builder.execute(skip_triggers=False)
            
        # 2. Fetch the target package sources and ensure build dir exists
        builder.fetch(pkg)
        pkg.build_dir.mkdir(parents=True, exist_ok=True)
        
        # 3. Form and run the final command
        raw_cmd = args.cmd
        if args.cmd_args:
            raw_cmd += " " + " ".join(args.cmd_args)
            
        cmd = builder.expand_command(raw_cmd, pkg, args.as_build_dep, features)
        
        print(f"\n>>> Running custom command for {pkg.name} in {pkg.build_dir}")
        builder.run_command(cmd, pkg.build_dir)

if __name__ == '__main__':
    main()
